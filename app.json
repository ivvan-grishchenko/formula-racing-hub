{
  "expo": {
    "name": "formula-racing-hub",
    "description": "A cross-platform app for exploring Formula-style racing—schedule, results, driver focus, and race-control highlights in a single hub.",
    "slug": "formula-racing-hub",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "githubUrl": "https://github.com/ivvan-grishchenko/formula-racing-hub",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "formula-racing-hub",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": {
        "dark": "./assets/images/ios-dark.png",
        "light": "./assets/images/ios-light.png",
        "tinted": "./assets/images/ios-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ivangrishchenko.formularacinghub"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-dark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-icon-light.png",
            "backgroundColor": "#090b0c"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-image"
    ],
    "experiments": {
      "reactCompiler": true,
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11334445-6fe5-4b24-8af8-1a8f0e7505b1"
      }
    }
  }
}
